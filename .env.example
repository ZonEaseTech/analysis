# ERPNext REST API 连接配置
# 复制本文件为 .env 并填入实际值
# 三种认证方式优先级：Cookie sid > API Key > 用户名密码

# 方案 1（最推荐）：从浏览器 Cookie 复制 sid
# 登录 ERPNext 后台 → F12 → Application → Cookies → sid
ERPNEXT_BASE_URL=https://your-erpnext.com
ERPNEXT_SID=your_sid_here

# 方案 2：API Key + API Secret
# ERPNEXT_BASE_URL=https://your-erpnext.com
# ERPNEXT_API_KEY=your_api_key_here
# ERPNEXT_API_SECRET=your_api_secret_here

# 方案 3：用户名 + 密码
# ERPNEXT_BASE_URL=https://your-erpnext.com
# ERPNEXT_USERNAME=admin@example.com
# ERPNEXT_PASSWORD=your_password_here

# 价格表名称（可选，默认 Buying - Internal，对齐 ttpos 成本毛利口径）
ERPNEXT_PRICE_LIST=Buying - Internal
