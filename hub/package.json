  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3"
  }
}
